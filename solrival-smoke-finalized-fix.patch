+/**
+ * Polls until the RPC reports the account holding at least `minLamports` at
+ * FINALIZED commitment. Funding can confirm while the finalized state the next
+ * transfer will be simulated against still shows zero — the source of the
+ * "found no record of a prior credit" race on devnet.
+ */
+async function waitForFinalizedBalance(pubkey, minLamports, timeoutMs = 45_000) {
+  const deadline = Date.now() + timeoutMs;
+  while (Date.now() < deadline) {
+    const bal = await connection.getBalance(pubkey, "finalized");
+    if (bal >= minLamports) return;
+    await new Promise((r) => setTimeout(r, 1_500));
+  }
+  throw new Error(
+    `Timed out waiting for ${pubkey.toBase58()} to reach ${minLamports} lamports (finalized). ` +
+      `The RPC may be lagging — rerun, or use a dedicated RPC via NEXT_PUBLIC_SOLANA_RPC_URL.`,
+  );
+}
