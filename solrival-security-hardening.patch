-
-  // Run an immediate first tick, then set up the interval
-  void tick()
-  handle = setInterval(() => void tick(), DEFAULT_POLL_INTERVAL_MS)
-
-  const pollerHandle: PollerHandle = {
-    stop: () => {
-      if (stopped) return
