-  console.info({
-    msg: 'poller_started',
-    duelId: ctx.duelId,
-    gameId: ctx.gameId,
-    intervalMs: DEFAULT_POLL_INTERVAL_MS,
-    timeoutAt: ctx.timeoutAt.toISOString(),
-  })
-
-  return pollerHandle
-}
