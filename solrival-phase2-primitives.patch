diff --git a/apps/web/src/components/ui/spinner.tsx b/apps/web/src/components/ui/spinner.tsx
new file mode 100644
index 0000000..6eb09c5
--- /dev/null
+++ b/apps/web/src/components/ui/spinner.tsx
@@ -0,0 +1,19 @@
+import { Loader2 } from "lucide-react";
+import { cn } from "@/lib/utils";
+
+/** Standalone loading indicator. Announces itself to screen readers. */
+export function Spinner({
+  className,
+  label = "Loading",
+}: {
+  className?: string;
+  label?: string;
+}) {
+  return (
+    <Loader2
+      role="status"
+      aria-label={label}
+      className={cn("h-4 w-4 animate-spin text-muted", className)}
+    />
+  );
+}
