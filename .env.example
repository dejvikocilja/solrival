# =============================================================================
# SolRival — Environment Variables (reference)
# Copy the relevant block into apps/web/.env.local and apps/verifier/.env.
# NEVER commit real values. NEXT_PUBLIC_* are exposed to the browser.
# =============================================================================

# ----- Database (Supabase Postgres) — used by web + verifier + db package -----
DATABASE_URL="postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true&connection_limit=1"  # pooled (runtime)
DIRECT_URL="postgresql://USER:PASS@HOST:5432/postgres"                                       # direct (migrations)

# ----- Supabase (realtime + storage + service role) -----
NEXT_PUBLIC_SUPABASE_URL="https://PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."          # client, RLS-scoped
SUPABASE_SERVICE_ROLE_KEY="..."              # server only — bypasses RLS, keep secret

# ----- Solana / Anchor -----
NEXT_PUBLIC_SOLANA_CLUSTER="devnet"          # devnet | mainnet-beta
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"   # use a paid RPC in prod
NEXT_PUBLIC_SOLRIVAL_PROGRAM_ID="HA38xW46mB8J6ZNdL3NAjRbJamDMGLoo4Eq6bJdU7W23"  # dedicated escrow program id (keypair in programs/solrival-escrow/)
NEXT_PUBLIC_PLATFORM_FEE_BPS="500"           # 5.00% — must equal on-chain constant

# Settlement signer — VERIFIER ONLY. Authority that can settle/refund a duel.
# On-chain rules restrict it to paying participants or refunding (cannot drain).
RESULT_AUTHORITY_KEYPAIR="[base58 secret key or path to keypair json]"
PLATFORM_FEE_WALLET="..."                    # fixed fee-collection pubkey (also pinned on-chain)

# ----- Auth (Sign-In With Solana session) — web -----
AUTH_JWT_SECRET="generate-32+-byte-random"
NEXT_PUBLIC_APP_URL="https://solrival.com"
SIWS_DOMAIN="solrival.com"
ADMIN_WALLET_ALLOWLIST="WALLET1,WALLET2"     # comma-separated admin pubkeys

# ----- Supercell game APIs — VERIFIER ONLY (tokens are IP-whitelisted) -----
CLASH_ROYALE_API_TOKEN="..."
CLASH_ROYALE_API_BASE_URL="https://api.clashroyale.com/v1"
BRAWL_STARS_API_TOKEN="..."
BRAWL_STARS_API_BASE_URL="https://api.brawlstars.com/v1"

# ----- Verifier runtime tuning -----
VERIFICATION_POLL_INTERVAL_MS="15000"
DUEL_VALIDITY_WINDOW_MIN="30"                # spec: duels expire after 30 min
QUEUE_SCHEMA="pgboss"                        # pg-boss schema name

# ----- Duel system -----
EXPIRE_CRON_SECRET="generate-random-secret"        # bearer for the duel crons (expire + verify)
WITHDRAWAL_CRON_SECRET="generate-another-secret"   # SEPARATE bearer for the treasury payout worker (moves real SOL)

# ----- Rate limiting (optional; enables shared limits across instances) -----
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
